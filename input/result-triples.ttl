  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/34.8480597%2C-114.6141315>;
  mpr:hasCircumstanceOfDisappearance """Dennis Samstag was 34 years old when he was last seen on 07/07/94 in Needles, CA. He was heading down to the Colorado River. Officers searched the dike and the riverbank with negative results. 
Samstag was described as 5'8\" tall, 150 lbs, medium length black hair, brown eyes,and he had a moustache. He is disabled. He was last seen wearing swim trunks and no shirt.
Fingerprints available at CAL-ID (909-890-5000)CAL-ID #LR #09-1098. Also refer to CII #A06471870 and FBI #27392V9. 
Reference DNA samples have been submitted to CA-DOJ and uploaded into CODIS when a profile has been developed."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/2752?nav"^^xsd:String;
