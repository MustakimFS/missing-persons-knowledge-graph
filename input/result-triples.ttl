mpr:2760 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Scotts%20Valley;
  rdfs:hasCountyOfOrigin mpr:Santa%20Cruz;
  rdfs:isOfAge mpr:66;
  rdfs:Case_Number mpr:MP29555;
  rdfs:DLC mpr:1990-04-11;
  rdfs:Legal_Name "Cindy Fawcett"^^xsd:String;
  rdfs:Coordinates mpr:37.0510595%2C-122.0146841;
  rdfs:Missing_Age mpr:32;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.0510595%2C-122.0146841>;
  mpr:hasCircumstanceOfDisappearance """Fawcett was employed as a bartender at the Friendly Fox in Scotts Valley at the time of her disappearance. Fawcett and a friend went on a motorcycle ride through the San Lorenzo Valley on April 11, 1990. The friend later drove Fawcett to the Friendly Fox to retrieve her truck, where she had parked it for the day. He dropped Fawcett off near the Friendly Fox at approximately 21:30 that evening and drove away.

Fawcett's truck remained in the bar's parking lot the following morning. She failed to arrive at work for her bar tending shift as scheduled, and her employer reported her as missing to the police. Fawcett's purse and driver's license were inside of her vehicle, but no other evidence was discovered. Foul play is suspected."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/29555?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/29555/Images/53170/Thumbnail"^^xsd:String .

