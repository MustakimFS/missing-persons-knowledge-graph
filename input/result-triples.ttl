mpr:1461 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Concord;
  rdfs:hasCountyOfOrigin mpr:Contra%20Costa;
  rdfs:isOfAge mpr:69;
  rdfs:Case_Number mpr:MP29872;
  rdfs:DLC mpr:2011-04-12;
  rdfs:Legal_Name "Deborah Hubbert"^^xsd:String;
  rdfs:Coordinates mpr:37.9876914%2C-122.0098642;
  rdfs:Missing_Age mpr:55;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.9876914%2C-122.0098642>;
  mpr:hasCircumstanceOfDisappearance """Hubbert went missing on 4/12/2011. Hubbert was last seen in the City of Oakland Ca. She made some vague statements asking for her personal property to be tended to prior to disappearing. She said she would be going away for a while but was not specific. 

Hubbert left her vehicle at her house and left no evidence of her direction of travel. Her cellular phone was within 30 miles of her residence when it was last used, the day she made these vague statements. 

Investigation into Hubbert’s financial records, cellular phone records, and personal history gave no evidence of her desire to disappear or cause harm to herself. It also did not reveal any persons that intended or desired to cause her any harm.

While her disappearance is odd, based on her statements prior to her being reported missing, it does not appear that criminal activity led to her disappearance."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/29872?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/29872/Images/53273/Thumbnail"^^xsd:String .

