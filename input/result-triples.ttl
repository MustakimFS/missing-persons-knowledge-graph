  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.2260616%2C-121.9302449>;
  mpr:hasCircumstanceOfDisappearance "At the time of this report on 4/24/24, Jonathan had reportedly been sleeping in his brother's blue, 2018 Toyota Prius which had been parked in the driveway of the reporting party's house on 4/22/24 and 4/2324. On 4/23/24, at approximately 0930 hours, the reporting party spoke with Jonathan in the car in the driveway. Jonathan told the reporting party that he just wanted to, \"Get away from everyone.\" The reporting party gave Jonathan $300 and asked him to come back to her residence by 1500 hours. The reporting party did not see Jonathan after he left and called to report him as missing on 4/24/24. The reporting party told law enforcement that she is concerned because she feels Jonathan may be mentally vulnerable and in need attention for his mental health."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/122148?nav"^^xsd:String;
