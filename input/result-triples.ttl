mpr:594 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Mountain%20View;
  rdfs:hasCountyOfOrigin mpr:Santa%20Clara;
  rdfs:isOfAge mpr:41;
  rdfs:Case_Number mpr:MP67671;
  rdfs:DLC mpr:2019-11-30;
  rdfs:Legal_Name "Alice Ku"^^xsd:String;
  rdfs:Coordinates mpr:37.4062237%2C-122.0781663;
  rdfs:Missing_Age mpr:36;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "Asian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.4062237%2C-122.0781663>;
  mpr:hasCircumstanceOfDisappearance "Ku traveled with her husband to Taiwan on 11/23/19. Ku and her husband went their separate ways on 11/29/19, with the plan being she was going to take a train from Hualien to Taipei to visit her family, and to reconnect with each other and travel back to the United States through SFO on 12/1/19. On 11/30/19, the husband received an e-mail from Ku requesting to extend her stay by a week and to change her flight date to 12/8/19. She has not been heard from since that e-mail was sent and was not on the return flight. Mountain View PD took the missing person case since Ku is a resident of the city in the event she re-enters the country. However, case is being actively investigated by the National Policy Agency Republic of China (Taiwan) since the last time she was physically seen was in Taiwan."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/67671?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/67671/Images/132007/Thumbnail"^^xsd:String .

