mpr:2956 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Fresno;
  rdfs:hasCountyOfOrigin mpr:Fresno;
  rdfs:isOfAge mpr:53;
  rdfs:Case_Number mpr:MP4023;
  rdfs:DLC mpr:1986-06-01;
  rdfs:Legal_Name "Theresa Bier"^^xsd:String;
  rdfs:Coordinates mpr:36.7377981%2C-119.7871247;
  rdfs:Missing_Age mpr:15;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/36.7377981%2C-119.7871247>;
  mpr:hasCircumstanceOfDisappearance """Theresa Ann Bier, of Fresno has not been seen since she and a man, reportedly became separated in the mountains after they had gone to look for Sasquatch, the legendary creature also known as Bigfoot.
The man, a self-proclaimed student of Bigfoot, went camping with Theresa in June near Shuteye Peak, about 25 miles northeast of Bass Lake, and was questioned by deputies when he returned without her. His explanation was that Bigfoot had abducted her. Foul play is suspected. Searches throughout that region produced no sign of Bier; she has never been seen again."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/4023?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/4023/Images/17210/Thumbnail"^^xsd:String .

