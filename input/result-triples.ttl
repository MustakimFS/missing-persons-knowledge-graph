  rdfs:Missing_Age mpr:74;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "Black / African American"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/34.1141743%2C-116.432235>;
  mpr:hasCircumstanceOfDisappearance "Melancon left his residence in the City of Victorville on October 7, 2020, at 0600 hours. Melancon left the residence in a 2015 Nissan Sentra with his cat. Melancon did not take his cell phone or his favorite hat. Melancon used his bank card the same day, once at a grocery store at 0700 in Victorville, and the other at 1600 at a convenience store near Landers California. On October 28, 2020, Melancon's 2015 Nissan Sentra was located by Bureau of Land Management in the remote desert of the Morongo Valley. No evidence was located in the vehicle. A four day search and rescue operation was conducted, Melancon was not located."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/75322?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/75322/Images/148430/Thumbnail"^^xsd:String .

