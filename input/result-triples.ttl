  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.7597481%2C-122.4750292>;
  mpr:hasCircumstanceOfDisappearance "Nolan was last seen April 20, 1994 in San Francisco, California. He is a native of Blacklion County Cavan, Ireland. In 1993 he went to New York where he spent 8 months. He then moved to San Francisco. On the 20 April 1994, he left his house and has never been seen since. He had just cashed a check for $500 at a Market Street bank in downtown San Francisco Bank. Friends described Nolan as despondent because he had been unable to find work. He left his resident alien card behind when he departed that day. His Irish Passport has never been located."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/28594?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/28594/Images/38042/Thumbnail"^^xsd:String .

