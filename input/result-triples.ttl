mpr:3199 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Carson;
  rdfs:hasCountyOfOrigin mpr:Los%20Angeles;
  rdfs:isOfAge mpr:61;
  rdfs:Case_Number mpr:MP17132;
  rdfs:DLC mpr:1981-08-09;
  rdfs:Legal_Name "Tracy Stewart"^^xsd:String;
  rdfs:Coordinates mpr:33.8316745%2C-118.281693;
  rdfs:Missing_Age mpr:18;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/33.8316745%2C-118.281693>;
  mpr:hasCircumstanceOfDisappearance """Tracy was last seen on August 9, 1981. Tracy Lea Stewart told her parents she was going out on a date with someone new. The 18-year-old high school graduate then bid her family farewell, met a young man at the front door and left her home in Carson. She was never heard from again. The man was later identified as Robert Wayne Beckett Jr. He was convicted in 1989 of murdering Stewart.

In 1995 a Los Angeles Superior Court jury found his father, Robert Wayne Beckett Sr., guilty of first-degree murder in Stewart's case. The older Beckett had made his son lure Tracy home, so the father could rape and kill her. 

The body was never recovered."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/17132?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/17132/Images/27868/Thumbnail"^^xsd:String .

mpr:Carson a <http://www.dbpedia.org/ontologyCarson> .

