  rdfs:DLC mpr:1971-01-18;
  rdfs:Legal_Name "Christine Eastin"^^xsd:String;
  rdfs:Coordinates mpr:37.6270256%2C-122.0496521;
  rdfs:Missing_Age mpr:19;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.6270256%2C-122.0496521>;
  mpr:hasCircumstanceOfDisappearance "Eastin borrowed her former boyfriends vehicle to go shopping on 1/18/71. Eastin told former boyfriend she was going to wash the vehicle, prior to returning it to him, and she would pick him up from work later in the evening. Former boyfriend called Eastin's residence after he got off work because Eastin had not picked him up. Former boyfriends vehicle was recovered on 1/19/71 at a car wash near Eastin's house. Vehicle found locked and secured. Eastin has not been seen or heard from since. Former boyfriend was interviewed by Police, however he had no information of Eastin's disappearance."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/8173?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/8173/Images/20417/Thumbnail"^^xsd:String .

mpr:Hayward a <http://www.dbpedia.org/ontologyHayward> .

mpr:3486 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Los%20Angeles;
  rdfs:hasCountyOfOrigin mpr:Los%20Angeles;
  rdfs:isOfAge mpr:72;
  rdfs:Case_Number mpr:MP32285;
  rdfs:DLC mpr:1970-11-14;
  rdfs:Legal_Name "Robin Graham"^^xsd:String;
  rdfs:Coordinates mpr:34.0880507%2C-118.2965121;
  rdfs:Missing_Age mpr:18;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/34.0880507%2C-118.2965121>;
  mpr:hasCircumstanceOfDisappearance """Graham was last seen on November 14, 1970 by a California Highway Patrol officer. She had been driving her boyfriends vehicle when she apparently ran out of gas and stalled on U.S. Highway 101 southbound near the Santa Monica Boulevard offramp at about 2:00 am.

The officer stopped to see if she needed help, but Ms. Graham said that help was already coming. She had just called her parents to inform them of her situation.

Later, the officer noticed a white male, 25-26 years of age, 5'8\" with dark hair, wearing bell bottom trousers and a white turtle neck top.talking to her. A 1958-1960 light blue Corvette hardtop was observed parked behind her vehicle at this time. The officer later assumed the man in the Corvette was the help she had called for. The next day, her parents searched for Robin and found her car, locked up and abandoned on the side of the freeway where she was last seen. She hasn't been heard from since."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/32285?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/32285/Images/40789/Thumbnail"^^xsd:String .

