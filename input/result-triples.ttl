mpr:887 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Fairfield;
  rdfs:hasCountyOfOrigin mpr:Solano;
  rdfs:isOfAge mpr:36;
  rdfs:Case_Number mpr:MP50924;
  rdfs:DLC mpr:2017-12-06;
  rdfs:Legal_Name "Kamron Morris"^^xsd:String;
  rdfs:Coordinates mpr:38.2493627%2C-122.0399969;
  rdfs:Missing_Age mpr:29;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "Black / African American"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/38.2493627%2C-122.0399969>;
  mpr:hasCircumstanceOfDisappearance "Kamron Morris was transient at the time of his disappearance. Mr. Morris's mother reported that she last saw her son in Solano County Jail in Fairfield, CA on December 6, 2017. He was released from jail the next day, Dec. 7, 2017. On Dec. 8, 2017, Mr. Morris's mother discovered that her son was released without his necessary medications, so she filled a prescription and attempted to locate her son to give him the meds. When she could not locate him, she left the meds with Mr. Morris's girlfriend and asked that she give them to her son. The girlfriend accepted the bag of meds and said she had not seen Mr. Morris since the day of his release from jail. Mr. Morris's mother has made repeated, unsuccessful attempts to locate her son, looking for him in the areas of Fairfield, Suisun City, and unincorporated Solano County (CA) that he was known to frequent at the time."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/50924?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/50924/Images/83286/Thumbnail"^^xsd:String .

mpr:Fairfield a <http://www.dbpedia.org/ontologyFairfield> .

