  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.6688205%2C-122.0807964>;
  mpr:hasCircumstanceOfDisappearance """Michaela was abducted by an unknown individual while trying to retrieve her scooter from him in front of the Rainbow Market on Mission Boulevard in Hayward, California. The suspect was between 18 - 24 years with a slender build. He had a pock marked or pimpled face and dirty blonde hair. He was driving an older model full-size car, possibly a gold or tan 4-door.

On 12-21-2020, David Misch was arrested for the kidnapping and murder of Michaela. Michaela's remains have not been located."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/49?nav"^^xsd:String;
