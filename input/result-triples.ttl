  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.957592%2C-119.119943>;
  mpr:hasCircumstanceOfDisappearance """Volker Puschkeit was traveling with Herbert Frank (NamUs MP #92222) from Cologne, Germany to the United States on vacation in October of 1994. According to police, the rental vehicle was discovered abandoned in a remote area of Mineral County, Nevada near Lucky Boy Pass in November of 1994. Both passports were discovered inside the vehicle with neither party being located. 

Volker and Herbert were last seen at a hotel in Lee Vining, California on 10/30/1994 where witnesses indicated they had been openly discussing winning $13,000 at a casino in Reno, Nevada during their trip."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/92221?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/92221/Images/179116/Thumbnail"^^xsd:String .

