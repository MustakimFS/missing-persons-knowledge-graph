mpr:1287 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Oceanside;
  rdfs:hasCountyOfOrigin mpr:San%20Diego;
  rdfs:isOfAge mpr:64;
  rdfs:Case_Number mpr:MP56904;
  rdfs:DLC mpr:2013-09-09;
  rdfs:Legal_Name "Loren Ruden"^^xsd:String;
  rdfs:Coordinates mpr:33.1924489%2C-117.3675233;
  rdfs:Missing_Age mpr:52;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/33.1924489%2C-117.3675233>;
  mpr:hasCircumstanceOfDisappearance "Loren Ruden was last seen by his wife, the morning of 09/09/13. She believed Loren had gone fishing that day. On 09/09/13 at around 7pm, Loren's dog was returned to their home by a man who said that they had found her swimming in the Oceanside Harbor. Loren's wife became worried and attempted to call Loren on his cell phone with no success. She then located Loren's vehicle and boat trailer parked across from the harbor boat launch ramp. An offshore search was conducted by both Oceanside Harbor units and the US Coast Guard. Neither Loren nor his boat were located. The following day, 09-10-13, Loren's boat was located off La Jolla Shores in San Diego."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/56904?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/56904/Images/99577/Thumbnail"^^xsd:String .

