mpr:6 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Milpitas;
  rdfs:hasCountyOfOrigin mpr:Santa%20Clara;
  rdfs:isOfAge mpr:28;
  rdfs:Case_Number mpr:MP129826;
  rdfs:DLC mpr:2024-08-02;
  rdfs:Legal_Name "Michael Griggs"^^xsd:String;
  rdfs:Coordinates mpr:37.4323341%2C-121.8995741;
  rdfs:Missing_Age mpr:28;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "Black / African American"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.4323341%2C-121.8995741>;
  mpr:hasCircumstanceOfDisappearance """On August 13, 2024, Michael Anthony Griggs family contacted the Milpitas Police Department to file a missing person report. Michael Griggs was last seen on August 2, 2024, just before he walked out of their residence at 163 Carnegie Drive.

Michael was wearing all black clothing and a black backpack when he left at approximately 11:45 PM. Family stated that it is unusual for him to be away for such a long period and not answer his phone. Law enforcement attempted to call Michael, but he did not answer. Family believes Michael might be at the Bill Wilson Center, as he likes that area. Michael does not drive and does not own a car; he uses the bus for transportation.

It is unknown if Michael has any social media accounts."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/129826?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/129826/Images/Default/Thumbnail"^^xsd:String .

