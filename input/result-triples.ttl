mpr:3028 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Los%20Angeles;
  rdfs:hasCountyOfOrigin mpr:Los%20Angeles;
  rdfs:isOfAge mpr:85;
  rdfs:Case_Number mpr:MP52695;
  rdfs:DLC mpr:1984-12-14;
  rdfs:Legal_Name "Howard Tokarsky"^^xsd:String;
  rdfs:Coordinates mpr:34.0549076%2C-118.242643;
  rdfs:Missing_Age mpr:45;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/34.0549076%2C-118.242643>;
  mpr:hasCircumstanceOfDisappearance """Tokarsky was last seen in Los Angeles, CA. The Granada Hills man left work early, telling his wife and secretary he was going to an unspecified desert site to practice shooting. 

Kern County sheriff's deputies on routine patrol found Tokarsky's Ford Bronco parked behind a market on the outskirts of Mojave. The keys to the unlocked vehicle were still in the ignition and Tokarsky's wallet, with no money, was found inside. Many of Tokarsky's personal belongings were found strewn throughout the vehicle including his broken glasses.

Tokarsky was operations manager of a Sylmar chemical company at the time."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/52695?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/52695/Images/86766/Thumbnail"^^xsd:String .

