  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/38.0268596%2C-121.5141615>;
  mpr:hasCircumstanceOfDisappearance "Gail Deann Skelton (A/K/A Gail Deann Brewer) disappeared from Herman and Helen's Marina on Empire Tract, where she was attending a party. She disappeared just a few months after her fiancee died in June of that year. Gail and her 1978 blue two-door Toyota were never seen again. She was wearing a blue plaid flannel shirt and blue jeans when she disappeared. There was a composite sketch of a man who was \"possibly connected\" to her - \"a white man, 25-30 years old, with dark hair, over 6 feet tall and thin build\"."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/50180?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/50180/Images/80143/Thumbnail"^^xsd:String .

