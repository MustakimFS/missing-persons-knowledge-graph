mpr:263 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:San%20Luis%20Obispo;
  rdfs:hasCountyOfOrigin mpr:San%20Luis%20Obispo;
  rdfs:isOfAge mpr:37;
  rdfs:Case_Number mpr:MP97054;
  rdfs:DLC mpr:2022-05-03;
  rdfs:Legal_Name "Brett Edgell"^^xsd:String;
  rdfs:Coordinates mpr:35.2827524%2C-120.6596156;
  rdfs:Missing_Age mpr:35;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/35.2827524%2C-120.6596156>;
  mpr:hasCircumstanceOfDisappearance "On 5-3-2022, BRETT EDGELL got into an argument with his girlfriend and left the residence in her vehicle with her cell phone and wallet inside. Later this same date, he left his girlfriend's vehicle at a car dealership and test drove a 1979 Ford Van. BRETT EDGELL never returned from the test drive and the vehicle was reported stolen. On 5-9-2022, CHP located the stolen Ford Van abandoned and vandalized on High Mountain Rd at Garcia Ridge in San Luis Obispo, CA. BRETT EDGELL's girlfriend's wallet and cellphone were located in the vicinity of the vehicle. There was no other evidence located and the immediate rural area was searched with search and rescue as well as helicopter, but nothing was located. BRETT EDGELL has not been seen or heard from by any family or friends since which is extremely unusual for him."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/97054?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/97054/Images/180996/Thumbnail"^^xsd:String .

mpr:San%20Luis%20Obispo a <http://www.dbpedia.org/ontologySan%20Luis%20Obispo> .

