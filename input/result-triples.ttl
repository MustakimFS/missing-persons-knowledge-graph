  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/34.0549076%2C-118.242643>;
  mpr:hasCircumstanceOfDisappearance "Ryan lived in Denver, CO with his beloved goldendoodle \"Blue.\" Around Thanksgiving of 2022 Ryan became ill and his health slowly began to deteriorate. He loaded up a U-Haul and him and his dog and went to L.A. in March 2024. A good Samaritan found us on Facebook in Early July 2024 and said Ryan was in Chinatown in Los Angeles sleeping on the street with his dog. That was the last time Ryan was seen, and the good Samaritan was no longer able to locate Ryan again."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/125972?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/125972/Images/209544/Thumbnail"^^xsd:String .

mpr:57 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Ukiah;
  rdfs:hasCountyOfOrigin mpr:Mendocino;
  rdfs:isOfAge mpr:25;
  rdfs:Case_Number mpr:MP118931;
  rdfs:DLC mpr:2024-02-14;
  rdfs:Legal_Name "Angel Murguia-Martinez"^^xsd:String;
  rdfs:Coordinates mpr:39.1501709%2C-123.2077831;
  rdfs:Missing_Age mpr:24;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "American Indian / Alaska Native"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/39.1501709%2C-123.2077831>;
  mpr:hasCircumstanceOfDisappearance """On 02/14/2024 at approximately 2300 hours, Angel Murguia-Martinez walked away from his residence located within the city limits of Ukiah. An emergency ping on Murguia-Martinez's cellular phone was conducted with negative results.
A MP report was filed for Murguia-Martinez, BOLO was issued and he was entered into MUPS. Based on the fact Murguia-Martinez is an indigenous person, CHP-ENTAC was notified and a Feather Alert was issued. Murguia-Martinez is described as being a American Indian adult, 5-08, 250 pounds with medium/long brown hair, green eyes and was last seen wearing a black zip-up hoodie, black pants, black shoes with a gray hat and glasses."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/118931?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/118931/Images/202734/Thumbnail"^^xsd:String .

