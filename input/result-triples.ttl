  rdfs:hasCountyOfOrigin mpr:Tuolumne;
  rdfs:isOfAge mpr:39;
  rdfs:Case_Number mpr:MP59279;
  rdfs:DLC mpr:2010-12-29;
  rdfs:Legal_Name "William Elgen"^^xsd:String;
  rdfs:Coordinates mpr:38.0385049%2C-120.2295831;
  rdfs:Missing_Age mpr:25;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/38.0385049%2C-120.2295831>;
  mpr:hasCircumstanceOfDisappearance """Elgen was last seen at a cabin on Mount Provo Road in Twain Harte, California on December 29, 2010. He has never been heard from again. He lived in Modesto, California at the time of his disappearance, but had been staying at with a friend at the friend's cabin. They arrived on December 26. A few days later, the friend left to go get some supplies in town.

 When Elgen's parents and two step-siblings arrived at the cabin for a surprise visit on December 29, he was gone. The door was unlocked, the power was turned off and the cabin was in disarray.

 Elgen's winter coat was left behind, as was his dog. Although the dog was housebroken, it had urinated inside the cabin. His family immediately called the police."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/59279?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/59279/Images/168419/Thumbnail"^^xsd:String .

