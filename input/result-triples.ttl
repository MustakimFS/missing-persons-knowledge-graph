  rdfs:Coordinates mpr:34.4933111%2C-117.3028803;
  rdfs:Missing_Age mpr:18;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/34.4933111%2C-117.3028803>;
  mpr:hasCircumstanceOfDisappearance """Keith was last seen in Victorville, California in August 26, 1991. He lived with his girlfriend and their daughter in the Spring Valley Lake area. His girlfriend stated that Keith's acquaintance drove to their residence that day and Keith left with him. Keith has never been heard from again. 

In November 2012, Romero was convicted of Keith's murder, and also with the murder of his roommate Spencer Watts. Watts was shot to death and his body was found in a shallow grave in Lucerne County, California in September 1991. Authorities believe Keith may be buried in the Adelanto, California area, but his body has never been found."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/19123?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/19123/Images/29570/Thumbnail"^^xsd:String .

