  rdfs:Legal_Name "Kieran Murphy"^^xsd:String;
  rdfs:Coordinates mpr:37.7749295%2C-122.4194155;
  rdfs:Missing_Age mpr:58;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.7749295%2C-122.4194155>;
  mpr:hasCircumstanceOfDisappearance "Kieran was last seen December 14, 2001 in San Francisco, CA. He may be in the company of his wife Ornaith. Their sailing vessel has been missing since December 15, 2001 from Jack London Square in Oakland, CA. The vessel is white with blue trim and a 1980 39 foot Fiberglass auxillary sail boat named the Sola III. The vessel has a distinct emblem of a round dark blue circle with a grey swirl inside located on both the right and left sides. The two are in the process of getting a divorce because of that friends say they doubt that the two went on a sailing voyage together. They also faced a potentially costly lawsuit stemming from a fire in one of their Sacramento apartment. The Coast Guard checked with harbormasters throughout the state for any sign of the couple or Ornaith Murphy's sloop."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/32077?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/32077/Images/40582/Thumbnail"^^xsd:String .

