  rdfs:Coordinates mpr:37.6879241%2C-122.4702079;
  rdfs:Missing_Age mpr:83;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.6879241%2C-122.4702079>;
  mpr:hasCircumstanceOfDisappearance """Bross was last seen at approximately 10:30 a.m. on April 2, 2001 in Daly City, California. She was en route to her apartment in Westlake Village, California at the time. Bross never returned home and has not been heard from again. Bross Walks with a slight limp. 

Bross's family said that it is uncharacteristic of her to leave without warning; she always kept her family informed of her whereabouts and made arrangements for someone to care for her cat if she planned on an extended absence. The animal was left behind when she disappeared. Bross does not drive and relies on public transportation. She was in good physical and mental condition at the time of her 2001 disappearance. Bross's case remains unsolved."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/38?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/38/Images/44591/Thumbnail"^^xsd:String .

