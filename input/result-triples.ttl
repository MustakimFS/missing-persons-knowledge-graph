mpr:2822 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:San%20Jose;
  rdfs:hasCountyOfOrigin mpr:Santa%20Clara;
  rdfs:isOfAge mpr:100;
  rdfs:Case_Number mpr:MP36472;
  rdfs:DLC mpr:1988-12-13;
  rdfs:Legal_Name "Joaquin Esteves"^^xsd:String;
  rdfs:Coordinates mpr:37.3382082%2C-121.8863286;
  rdfs:Missing_Age mpr:64;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian, Hispanic / Latino"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.3382082%2C-121.8863286>;
  mpr:hasCircumstanceOfDisappearance """Esteves was last seen on December 13, 1988 in San Jose, CA at 11:30, driving away from his office at 1236 East Santa Clara Street.

An acquaintance waved to Esteves as he drove off. Esteves returned the wave, and the witness said nothing appeared wrong. Esteves was apparently headed for an 11:30 appointment to do some translating in Los Gatos. He never showed up.

Esteves left the house each day at 9AM, came home for lunch at noon and then at 4:30 for dinner. His family knew something was wrong when he failed to make his usual call home from his real estate office. Nothing was found disturbed at his office but they called police when they realized Esteves and his car were gone and his identification papers and money were still in the office."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/36472?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/36472/Images/7712/Thumbnail"^^xsd:String .

