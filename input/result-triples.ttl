  rdfs:Coordinates mpr:33.9401088%2C-118.1331593;
  rdfs:Missing_Age mpr:26;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/33.9401088%2C-118.1331593>;
  mpr:hasCircumstanceOfDisappearance """The family reported Teresa missing 4 years after her they last heard from her. Teresa lived in Downey, CA, but the family's last contact with her was on or around May 17, 1987 when she called them and told them that she was traveling with her husband, possibly through Arizona, on their way to Mexico. She has not been seen or heard from since.

She is described as a white female, 6'0\", 200 lbs, with brown hair and hazel eyes. She has a tattoo \"Mom\" on her left shoulder and a butterfly tattoo on her right shoulder. She wore prescription eyeglasses."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/10135?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/10135/Images/22676/Thumbnail"^^xsd:String .

