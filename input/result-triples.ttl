mpr:1779 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Lake%20Forest;
  rdfs:hasCountyOfOrigin mpr:Orange;
  rdfs:isOfAge mpr:74;
  rdfs:Case_Number mpr:MP306;
  rdfs:DLC mpr:2006-12-05;
  rdfs:Legal_Name "David Boone"^^xsd:String;
  rdfs:Coordinates mpr:33.6469437%2C-117.6861023;
  rdfs:Missing_Age mpr:56;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/33.6469437%2C-117.6861023>;
  mpr:hasCircumstanceOfDisappearance """Boone was last seen at approximately 2:00 p.m. on December 5, 2006 at his residence in the vicinity of Town Center Drive in Lake Forest, California. He has never been heard from again. His family reported him missing early the next morning when he did not come home.
 
Bloodhounds subsequently tracked Boone's scent from his apartment to the Whiting Ranch Wilderness Park nearby. The park is a popular place for hiking and bike riding. Authorities believe Boone may have gone hiking at the park on the day of his disappearance. An extensive week long search of the park was conducted utilizing air support, horses, bloodhounds, off road vehicles, as well as, several Search and Resue personnel yielding negative results. Investigators believe that if Boone did in fact get lost or injured while hiking, he could not have survived long in the cold winter weather."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/306?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/306/Images/13281/Thumbnail"^^xsd:String .

