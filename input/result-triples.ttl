  rdfs:Coordinates mpr:37.6436199%2C-121.8676464;
  rdfs:Missing_Age mpr:52;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.6436199%2C-121.8676464>;
  mpr:hasCircumstanceOfDisappearance "Robert Canon visited the San Francisco Bay Area for a convention with a friend. He was last seen at the East Pleasanton BART station on 10/09/2011. He was supposed to ride BART to the San Francisco airport where he was to catch a returning flight back to Oklahoma. Canon's backpack was found on the Golden Gate Bridge with his cell phone and laptop computer. His clothing bag was never found. Delta Airline confirmed that Robert never checked in for his returning flight. a combined investigation with the Golden Gate Bridge Highway and Transportation District determined that Robert Canon was on the Golden Gate Bridge on 10/09/2011 and was not seen exiting the bridge."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/90075?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/90075/Images/172604/Thumbnail"^^xsd:String .

