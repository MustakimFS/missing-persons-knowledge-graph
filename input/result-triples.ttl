mpr:2762 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Imperial%20Beach;
  rdfs:hasCountyOfOrigin mpr:San%20Diego;
  rdfs:isOfAge mpr:77;
  rdfs:Case_Number mpr:MP26027;
  rdfs:DLC mpr:1990-03-24;
  rdfs:Legal_Name "Stanley Post"^^xsd:String;
  rdfs:Coordinates mpr:32.5839444%2C-117.1130849;
  rdfs:Missing_Age mpr:42;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/32.5839444%2C-117.1130849>;
  mpr:hasCircumstanceOfDisappearance """Stanley L. Post, was last seen on the morning of March 24, 1990 by his roommates when he left in his truck towing his 16-foot boat in Imperial Beach, CA.

Post left Shelter Island in his 16-foot boat but failed to return that night as expected. His car and trailer were found parked near the launch ramp.

He was reported missing by his supervisor at IBM. Post told family that he was going fishing. When he didn't report to work, they went looking for him and found his truck and empty trailer at the Shelter Island public boat launching ramp.

After he was reported missing, Coast Guard helicopters searched from Point Loma to Ensenada for Mr. Post's small pleasure boat, and the Coast Guard called harbors from San Diego to Los Angeles yet no trace of him was found."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/26027?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/26027/Images/35813/Thumbnail"^^xsd:String .

