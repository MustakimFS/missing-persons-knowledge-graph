  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/41.8351867%2C-122.8520587>;
  mpr:hasCircumstanceOfDisappearance "M. Andrus was last seen by family on 8- 20-87, in Davis, CA. While distraught from an argument and contemplating suicide, M. Andrus left Davis, Ca. driving a vehicle . On 9-5-87, a F&G Officer located M. Andrus' vehicle in the Beaver Creek wilderness area, Siskiyou County. It was parked & unoccupied on a Forrest Road. From the license plate info., the officer contacted M. Andrus' family in Davis, Ca. who reported her missing. Local law enforcement who hunt the Beaver Creek area, reported seeing the vehicle unoccupied as early as 8-20-87. A Klamath River market store owner recalled seeing M. Andrus at the store in late Aug. '87. She had asked about local campgrounds. After several searches of the Beaver Creek area, M. Andrus was never located."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/36221?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/36221/Images/56461/Thumbnail"^^xsd:String .

