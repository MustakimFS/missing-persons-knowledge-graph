mpr:3203 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Rescue;
  rdfs:hasCountyOfOrigin mpr:El%20Dorado;
  rdfs:isOfAge mpr:64;
  rdfs:Case_Number mpr:MP34972;
  rdfs:DLC mpr:1981-07-31;
  rdfs:Legal_Name "Tommi Cooper"^^xsd:String;
  rdfs:Coordinates mpr:38.7148404%2C-120.9528258;
  rdfs:Missing_Age mpr:21;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/38.7148404%2C-120.9528258>;
  mpr:hasCircumstanceOfDisappearance """Tommi Lee Cooper was last seen on July 31, 1981 driving towards Sacramento where she worked at the Sun Club, a massage parlor. She left her 1 1/2-year-old child with a friend and indicated she may go to Reno, NV or a concert in Oakland, CA.

However, she never came back to pick up her child and failed to show up at work the following Monday, August 3, or the rest of the week.

On August 13, Cooper's white and yellow 1977 Dodge Aspen was found abandoned in Sacramento at 51st and Woodbine. There was money in the glove compartment and a make-up kit on the rear seat."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/34972?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/34972/Images/42923/Thumbnail"^^xsd:String .

