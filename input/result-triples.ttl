mpr:2851 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Yosemite%20National%20Park;
  rdfs:hasCountyOfOrigin mpr:Mariposa;
  rdfs:isOfAge mpr:61;
  rdfs:Case_Number mpr:MP28821;
  rdfs:DLC mpr:1988-07-05;
  rdfs:Legal_Name "Timothy Barnes"^^xsd:String;
  rdfs:Coordinates mpr:37.8651011%2C-119.5383294;
  rdfs:Missing_Age mpr:24;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.8651011%2C-119.5383294>;
  mpr:hasCircumstanceOfDisappearance "At the time of his disappearance, Timothy Barnes was a resident of Rancho Cucamonga, California. He left Tenaya Lakes near Highway 120 east of Tioga Road in California at approximately 9:00 AM on July 5, 1988. Barnes planned to hike to the Polly Dome Lakes in Yosemite National Park, which are located approximately three miles from Tenaya Lakes. He failed to return later that day as scheduled and has never been heard from since. His friends reported him as a missing person to park service rangers the following morning. An extensive search of the surrounding area failed to produce any evidence as to his whereabouts."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/28821?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/28821/Images/38201/Thumbnail"^^xsd:String .

mpr:Yosemite%20National%20Park a <http://www.dbpedia.org/ontologyYosemite%20National%20Park> .

