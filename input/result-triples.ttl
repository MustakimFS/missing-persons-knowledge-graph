  rdfs:Coordinates mpr:41.7354186%2C-122.6344708;
  rdfs:Missing_Age mpr:52;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/41.7354186%2C-122.6344708>;
  mpr:hasCircumstanceOfDisappearance """Lemuel Ray Addington was last seen on 07/10/1998 after he was approached by Yreka Police Department (YPD) Officers for trespassing at Amerigas on Hwy 3 in Yreka, CA. He was last seen walking down Deer Creek towards a field. Many local searches were conducted by Siskiyou County Search and Rescue with negative results. Mr. Addington has ties to Dorris, CA.
 An unconfirmed citizen sighting of Mr. Addington occurred on 11/12/1998 near a Goodwill store in Medford, OR. by a resident of Dorris, CA. who stated that Mr. Addington responded to a greeting by name. Medford PD was notified and missing person flyers were posted. There have been no further sightings of Mr. Addington."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/115357?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/115357/Images/Default/Thumbnail"^^xsd:String .

