mpr:3406 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Yosemite%20National%20Park;
  rdfs:hasCountyOfOrigin mpr:Mariposa;
  rdfs:isOfAge mpr:68;
  rdfs:Case_Number mpr:MP61579;
  rdfs:DLC mpr:1975-09-01;
  rdfs:Legal_Name "Fred Comstock"^^xsd:String;
  rdfs:Coordinates mpr:37.8651011%2C-119.5383294;
  rdfs:Missing_Age mpr:19;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.8651011%2C-119.5383294>;
  mpr:hasCircumstanceOfDisappearance "Fred Comstock was hiking in Yosemite National Park with a female companion and her son whom he had recently met. While at Vogelsang High Sierra Camp, they agreed that Comstock would hike back to Tuolumne Meadows to collect his companion's car and drive it to Yosemite Valley where he would meet with her. Comstock was never seen again and his personal items, including a wallet, were left in the companion's car."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/61579?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/61579/Images/118293/Thumbnail"^^xsd:String .

mpr:3407 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Cedar%20Grove;
  rdfs:hasCountyOfOrigin mpr:Fresno;
  rdfs:isOfAge mpr:115;
  rdfs:Case_Number mpr:MP114223;
  rdfs:DLC mpr:1975-08-19;
  rdfs:Legal_Name "Fred Gist"^^xsd:String;
  rdfs:Coordinates mpr:36.790833%2C-118.669444;
  rdfs:Missing_Age mpr:66;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/36.790833%2C-118.669444>;
  mpr:hasCircumstanceOfDisappearance "On August 19, 1975, Fred Gist and two hiking partners departed Cedar Grove on horseback intending to reach Simpson Meadow within Kings Canyon National Park for a multi-day camping trip. The three men overshot their designated camping site by approximately 2 miles. The Cedar Grove horse packer, a few miles behind, caught up to the three men and advised them to return to the designated campsite with the horses. Mr. Gist refused to return to the campsite. Mr. Gist was left with some food rations and instructed to remain at that location so his party could rendezvous with him in the morning. The horse packer also took Mr. Gist's horse back to the campsite with the group. Mr. Gist was not seen again. A multi-day search-and-rescue uncovered no sign of Mr. Gist."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/114223?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/114223/Images/Default/Thumbnail"^^xsd:String .

mpr:Cedar%20Grove a <http://www.dbpedia.org/ontologyCedar%20Grove> .

mpr:3408 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Piru;
  rdfs:hasCountyOfOrigin mpr:Ventura;
  rdfs:isOfAge mpr:73;
  rdfs:Case_Number mpr:MP37661;
  rdfs:DLC mpr:1975-08-06;
  rdfs:Legal_Name "Tanya Ruiz"^^xsd:String;
  rdfs:Coordinates mpr:34.4152743%2C-118.7939824;
  rdfs:Missing_Age mpr:24;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/34.4152743%2C-118.7939824>;
  mpr:hasCircumstanceOfDisappearance """Tanya Ruiz was last seen at the Edwards Ranch near Piru, CA, where she lived with her husband. Tanya had been visiting her grandmother the preceding three or four days. When she did not meet her grandmother on Sunday as planned, the family began to search for Tanya. 

After trying for a month to locate Tanya, her mother reported her disappearance to the sheriff, whose deputy eventually interviewed her husband. According to the deputy, her husband seemed unconcerned about his wife's whereabouts, and told the deputy that Tanya had taken with her $150 to $200 and some clothes when she left.

Without any leads, the case was closed until the discovery in 1979 of the bodies of her husband's subsequent wife and her son, whom he buried in his backyard."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/37661?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/37661/Images/73891/Thumbnail"^^xsd:String .

