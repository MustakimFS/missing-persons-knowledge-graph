mpr:3304 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Rancho%20Palos%20Verde;
  rdfs:hasCountyOfOrigin mpr:Los%20Angeles;
  rdfs:isOfAge mpr:90;
  rdfs:Case_Number mpr:MP14012;
  rdfs:DLC mpr:1979-02-12;
  rdfs:Legal_Name "Patricia Calatrello"^^xsd:String;
  rdfs:Coordinates mpr:33.7793751%2C-118.3520389;
  rdfs:Missing_Age mpr:44;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/33.7793751%2C-118.3520389>;
  mpr:hasCircumstanceOfDisappearance """On 02-13-1979, the boat the missing person had been on was found adrift in the Catalina Channel. On board was the missing person's husband was transported to the hospital.

Per the husband, the missing person and her husband left San Pedro on Saturday, 02-10-1979 enroute to Catalina Island. They got lost and tried to head home on Saturday night and all day Sunday trying to get home, but were still lost. During the early morning hours of 02-12-1979, the husband woke up but could not find the missing person on the boat. Due the emergency, the husband drifted in his boat until Tuesday morning (02-13-1979) when a passing boat offered help. A search for the missing person met with negative results."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/14012?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/14012/Images/26067/Thumbnail"^^xsd:String .

