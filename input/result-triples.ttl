  rdfs:Legal_Name "Elizabeth Ramos"^^xsd:String;
  rdfs:Coordinates mpr:35.3732921%2C-119.0187125;
  rdfs:Missing_Age mpr:1;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "Hispanic / Latino"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/35.3732921%2C-119.0187125>;
  mpr:hasCircumstanceOfDisappearance """Elizabeth was last seen in August 1989 in Bakersfield, CA, with mother Marina Ramos getting into a black SUV with a Hispanic male, 30-40 years of age wearing black glasses. At that time, the mother stated they were on their way to Ontario, CA. The mother was later found deceased in Dolan Springs, AZ in December 1989. She was unidentified and remained a Jane Doe until December 2022. When she was identified and family members were located, law enforcement was notified of the missing children. 

Elizabeth's sister was also last seen on this date and her case information can be found at: MP101376"""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/101374?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/101374/Images/Default/Thumbnail"^^xsd:String .

