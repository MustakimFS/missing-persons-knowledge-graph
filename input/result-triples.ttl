mpr:1008 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Woodland;
  rdfs:hasCountyOfOrigin mpr:Yolo;
  rdfs:isOfAge mpr:25;
  rdfs:Case_Number mpr:MP37498;
  rdfs:DLC mpr:2016-11-04;
  rdfs:Legal_Name "Elijah Moore"^^xsd:String;
  rdfs:Coordinates mpr:38.67851570000001%2C-121.7732971;
  rdfs:Missing_Age mpr:17;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "Black / African American"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/38.67851570000001%2C-121.7732971>;
  mpr:hasCircumstanceOfDisappearance """Elijah Moore, a male from Woodland, California, was reported missing by his mother on Monday, November 6, 2016. She had not seen or heard from her son since Friday, November 4, 2016. On that date, Elijah attended school and later cashed a check at California Check Cashing located at 115 Main Street in Woodland, where he was last seen. Elijah Moore and Enrique Rios, who disappeared three weeks earlier, are friends who both attended Cesar Chavez Community School in Woodland, California. They vanished 25
days apart with little evidence to indicate where they went or who, if anyone, they may be with.
This case is being investigated by the Federal Bureau of Investigation and the Woodland Police Department.
If you have any information concerning this case, please contact the FBI's Toll-Free Tipline at 1-800-CALL-FBI (1-800-225-5324), your local FBI
office, or the nearest American Embassy or Consulate. Tips may be offered anonymously."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/37498?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/37498/Images/72255/Thumbnail"^^xsd:String .

