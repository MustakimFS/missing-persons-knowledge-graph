  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/33.9516114%2C-118.3875775>;
  mpr:hasCircumstanceOfDisappearance "Jonke, a retired druggist, left Los Angeles on June 8, 1983, via Pan Am Airlines with an eventual destination of Berlin, West Germany. Jonke stayed at the Cromwell-Tudor Court hotel in London, England from June 9 to June 14, then checked out of the hotel at approximately noontime on June 14 and has not been seen or heard from since. He had planned to go to Paris, then Berlin."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/126391?nav"^^xsd:String;
