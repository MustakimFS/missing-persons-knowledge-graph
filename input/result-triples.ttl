  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/34.1599885%2C-119.1274334>;
  mpr:hasCircumstanceOfDisappearance "MP was at his home w/long-time friend. MP told friend that MP's cousin was going to pick him up to go to Tijuana. At 2000 hours MP got a call from a subject he identified as his female cousin. MP immediately left the home. About 2 to 3 minutes later MP's long-time friend followed MP outside the home but could not see MP. During investigation it was discovered that another subject identified by the police had been the one to call MP and drove MP from Oxnard to Tijuana. They were followed by one of the subject's ex-tenants. MP's passage into Tijuana has yet to be confirmed by California DOJ."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/53556?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/53556/Images/88305/Thumbnail"^^xsd:String .

