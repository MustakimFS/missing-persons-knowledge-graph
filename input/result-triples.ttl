  rdfs:Missing_Age mpr:70;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "Hispanic / Latino"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.3785351%2C-122.086585>;
  mpr:hasCircumstanceOfDisappearance "On 4/12/24 at approximately 1500 hours, Andrew Herrera was reported missing. The reporting party (RP) stated that she had not heard from Herrera since 04/08/2024. (RP) advised that she was only his caseworker and knew that Herrera lived with two roommates.. On 4/8/24 Herrera advised (RP) that he had been discharged from the hospital in Mountain View. (RP) called Herrera's roommates on 4/12/24 and who at that time advised that they last heard from Herrera on 4/10/24. (RP) stated that due to his age and his inability to walk without his cane, she was concerned for his well being. Herrera has no known medical issues, has a valid driver's license but no known associated vehicles. On 5/1/24, law enforcement contacted the same roommates who confirmed they still had not seen Herrera over the past month. Multiple unsuccessful attempts have been made to contact him.."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/121256?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/121256/Images/203876/Thumbnail"^^xsd:String .

