mpr:1539 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:San%20Dimas%20Canyon;
  rdfs:hasCountyOfOrigin mpr:Los%20Angeles;
  rdfs:isOfAge mpr:66;
  rdfs:Case_Number mpr:MP100929;
  rdfs:DLC mpr:2010-04-01;
  rdfs:Legal_Name "Frank Martinez"^^xsd:String;
  rdfs:Coordinates mpr:34.1420824%2C-117.7766362;
  rdfs:Missing_Age mpr:51;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "Hispanic / Latino"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/34.1420824%2C-117.7766362>;
  mpr:hasCircumstanceOfDisappearance """Frank Martinez was last seen on April 1, 2010 and was reported missing by relatives. U.S. Forest Service personnel found his truck parked at the top of San Dimas Canyon Road near the reservoir. In the vehicle were found his keys, which were in the ignition, and his cell phone. The windows were rolled down and there were no tracks leading away from the vehicle.

Law enforcement officials and the San Dimas Mountain Rescue team of the Los Angeles County Sheriff's Department searched the San Dimas Canyon area as well as the shoreline of San Dimas Reservoir with dogs and a helicopter, but he was not located. The search was called off after two weeks."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/100929?nav"^^xsd:String;
