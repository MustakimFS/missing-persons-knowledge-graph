  rdfs:Coordinates mpr:33.9250147%2C-116.6383477;
  rdfs:Missing_Age mpr:28;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/33.9250147%2C-116.6383477>;
  mpr:hasCircumstanceOfDisappearance """Randy was dropped off by mother Oct 10,1988 approx 630am at I-10 and the Whitewater, CA exit to go hiking and camping for a few days (Tipton and Whitewater Roads). He had his Army back pack containing some food in Tupperware. Randy said was going hiking in the San Jacinto mountains. He was never seen or heard from again. 
Searches by law enforcement and private sources resulted in no trace found. Randy had survival training in the Army and worked for California Dept of Forestry. He was also a volunteer firefighter for Bostonia CA fire dept."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/2705?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/2705/Images/16214/Thumbnail"^^xsd:String .

