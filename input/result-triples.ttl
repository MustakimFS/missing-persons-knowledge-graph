  rdfs:Coordinates mpr:34.2819461%2C-118.4389719;
  rdfs:Missing_Age mpr:32;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "Hispanic / Latino"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/34.2819461%2C-118.4389719>;
  mpr:hasCircumstanceOfDisappearance """Dora was last seen at approximately 23.00 at her residence in the vicinity of the 200 block of Lazard Street in San Fernando, CA.


Her gray 1997 Chevrolet Astro van with a dark blue top, was later located abandoned on San Fernando, Mission Boulevard in Mission Hills, CA., two miles from the missing woman's home. Residents told investigators the van had been parked on the street between late May 8 and early May 9. A woman recognized the van from a newspaper story.

Friends and relatives said Silva has no history of disappearing or leaving unannounced. She has not contacted her extensive network of family and friends and coworkers.
Police officers, sheriff's deputies and volunteers searched El Cariso Regional Park in Sylmar on May 22, 1999 but found no clues."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/29552?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/29552/Images/38798/Thumbnail"^^xsd:String .

