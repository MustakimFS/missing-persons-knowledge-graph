mpr:1695 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Cayucos;
  rdfs:hasCountyOfOrigin mpr:San%20Luis%20Obispo;
  rdfs:isOfAge mpr:101;
  rdfs:Case_Number mpr:MP36316;
  rdfs:DLC mpr:2008-02-20;
  rdfs:Legal_Name "Dorothy Autrey"^^xsd:String;
  rdfs:Coordinates mpr:35.4427511%2C-120.8921254;
  rdfs:Missing_Age mpr:84;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/35.4427511%2C-120.8921254>;
  mpr:hasCircumstanceOfDisappearance "Autrey was last seen at her residence in Cayucos on February 20, 2008 at 9 pm. Her grandson claimed he noticed she was not at the residence the following day, saying it was not unusual. Her vehicle was left at the residence but her purse was gone. Autrey was reported missing at 7.30 pm on February 20, 2008. The following month, her grandson confessed to her murder saying he killed her at her home where he also lived. Money was apparently not a motive but her grandson is known to have an alcohol problem. It is suspected that he dumped her body north of Ragged Point but despite extensive searches of the area by crews her body has not been recovered."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/36316?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/36316/Images/44032/Thumbnail"^^xsd:String .

