mpr:2805 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Fremont;
  rdfs:hasCountyOfOrigin mpr:Alameda;
  rdfs:isOfAge mpr:60;
  rdfs:Case_Number mpr:MP25569;
  rdfs:DLC mpr:1989-02-27;
  rdfs:Legal_Name "Sheri Muhleman"^^xsd:String;
  rdfs:Coordinates mpr:37.5482697%2C-121.9885719;
  rdfs:Missing_Age mpr:25;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.5482697%2C-121.9885719>;
  mpr:hasCircumstanceOfDisappearance """Sheri Muhleman was last seen at 9:30 a.m on February 27, 1989 in Fremont, California, by her boyfriend's sister at the home Sheri lived at with her boyfriend and their daughter. When Sheri's mother did not hear from her daughter for two weeks, she called police. 

Sheri was facing a $2,500 warrant for an arrest on charges of being under the influence of drugs. But she was in touch with family members almost daily before her disappearance, and police do not believe she tried to skip out on the warrant. 

The boyfriend told police he last saw her sleeping at about 8:00 a.m, when he left the house for his job at his landscaping business. When he got home later that day, she was gone."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/25569?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/25569/Images/35493/Thumbnail"^^xsd:String .

