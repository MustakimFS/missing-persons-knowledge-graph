mpr:1694 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Rancho%20Palos%20Verdes;
  rdfs:hasCountyOfOrigin mpr:Los%20Angeles;
  rdfs:isOfAge mpr:40;
  rdfs:Case_Number mpr:MP102259;
  rdfs:DLC mpr:2008-02-24;
  rdfs:Legal_Name "James Goh"^^xsd:String;
  rdfs:Coordinates mpr:33.7456493%2C-118.3637264;
  rdfs:Missing_Age mpr:23;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "Asian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/33.7456493%2C-118.3637264>;
  mpr:hasCircumstanceOfDisappearance "James Goh and two friends had climbed over the railing that runs along Calle Entradero beach shore in the Oceanfront Estates area of Rancho Palos Verdes and walked down 40 feet on a narrow trail to the rocky shoreline near the Point Vicente Lighthouse on Sunday February 24, 2008. At approximately 6:35 p.m., a 15- to 20-foot wave hit the three and swept them out. Goh’s friends were able to get back to shore, but James was swept under and disappeared."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/102259?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/102259/Images/187192/Thumbnail"^^xsd:String .

