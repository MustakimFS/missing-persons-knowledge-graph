mpr:Hoopa a <http://www.dbpedia.org/ontologyHoopa> .

mpr:1498 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Calexico;
  rdfs:hasCountyOfOrigin mpr:Imperial;
  rdfs:isOfAge mpr:36;
  rdfs:Case_Number mpr:MP110096;
  rdfs:DLC mpr:2010-09-23;
  rdfs:Legal_Name "Jose Medina"^^xsd:String;
  rdfs:Coordinates mpr:32.6789476%2C-115.4988834;
  rdfs:Missing_Age mpr:22;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "Hispanic / Latino"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/32.6789476%2C-115.4988834>;
  mpr:hasCircumstanceOfDisappearance """Jose was released from Dalano Prison in February 2010. He was stopped in Fresno and removed and returned to Mexico. In September 2010, Jose was trying to enter the United States illegally a second time. Jose was stopped and detained. On 09/23/10, he was interviewed and sent back to Mexico. Jose's family has not spoken to him since then. Jose's sister advised her father had paid someone to try and bring Jose back to the US, but that subject called her father and advised him Jose was caught by immigration. Jose's family did not have any information for the subject they paid to bring Jose to the US and they have not heard from Jose. 

Jose did not have a vehicle or a cellphone. Jose used the names Jose Audel Median and Jose Audel Villacana-Medina. Jose was from Michocan, Mexico. His family in Mexico have not seen Jose. Jose was about 22 when he was last seen."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/110096?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/110096/Images/194847/Thumbnail"^^xsd:String .

mpr:Calexico a <http://www.dbpedia.org/ontologyCalexico> .

mpr:1499 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Indio;
  rdfs:hasCountyOfOrigin mpr:Riverside;
  rdfs:isOfAge mpr:75;
  rdfs:Case_Number mpr:MP113793;
  rdfs:DLC mpr:2010-09-03;
  rdfs:Legal_Name "Efren Perez"^^xsd:String;
  rdfs:Coordinates mpr:33.7140561%2C-116.2186488;
  rdfs:Missing_Age mpr:61;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "Hispanic / Latino"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/33.7140561%2C-116.2186488>;
  mpr:hasCircumstanceOfDisappearance "Efren was arrested and deported back to Mexico. On 09/03/10, Efren called his sister and told her he was going to try to cross the border back into the US. No one has heard from him since. Efren had an apartment in Mexicali Mexico that was undisturbed and Efren never returned. Efren was in the hospital for two days regarding medical issues and was deported about a week after his release. Efren's daughters have reported him missing in Mexico and checked all the hospitals and morgues. They also passed out fliers in Mexico, but they have not heard any information."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/113793?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/113793/Images/197298/Thumbnail"^^xsd:String .

