  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/34.0948204%2C-117.9073244>;
  mpr:hasCircumstanceOfDisappearance "On August 3rd, 1995 Joseph Isabel Rincon was confronted by his apartment manager about the over due rent for the month of August. It is unknown what was said during this conversation but it was the last time MP-Rincon was seen. On August 14th, 1995 his sister went to his apartment to check on him since she had not heard from him. He was not there and the interior of the apartment did not show any signs of a struggle or anything unusual. MP-Rincon was allegedly last seen two years after he was reported missing in Downtown Los Angeles in the area of 3rd and Hill Street. Mp-Rincon may be in need of medical attention."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/66252?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/66252/Images/129337/Thumbnail"^^xsd:String .

