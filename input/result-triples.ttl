mpr:2312 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Los%20Angeles;
  rdfs:hasCountyOfOrigin mpr:Los%20Angeles;
  rdfs:isOfAge mpr:97;
  rdfs:Case_Number mpr:MP126399;
  rdfs:DLC mpr:1997-10-29;
  rdfs:Legal_Name "Richard Davison"^^xsd:String;
  rdfs:Coordinates mpr:33.9516114%2C-118.3875775;
  rdfs:Missing_Age mpr:70;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/33.9516114%2C-118.3875775>;
  mpr:hasCircumstanceOfDisappearance "Davison was last scene when he left his residence on the 7900 block of Belton Dr, Los Angeles on October 29, 1997, at approximately 0830 hrs. His vehicle was found at the docks in Marina Del Rey, and his boat, Venturess III, was missing. A witness saw Davison get underway on his boat at 1200 hrs on October 29. On October 30, LASD found the boat grounded on Dockwieler State Beach with no one aboard. The boat's navigation equipment was in the \"on\" position, it was not in gear, the ignition was shut off, and the auto-pilot system was on. The pilot side door was open, and the boat's inflatable was missing. The pilot navigation system indicated a last course of (211) degrees from Marina Del Rey. A search of the area yielded negative results."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/126399?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/126399/Images/208622/Thumbnail"^^xsd:String .

