  rdfs:Coordinates mpr:38.5128714%2C-121.4970294;
  rdfs:Missing_Age mpr:27;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/38.5128714%2C-121.4970294>;
  mpr:hasCircumstanceOfDisappearance "Norma and her sons Thomas (NamUs 33819) and Richard (NamUs 33817) disappeared from Sacramento, California on July 15, 1978. Relatives had not been able to make contact with Norma for several days and on July 24th, relatives went to the Houghlands' apartment and found it intact, with all their clothing and belongings inside and some dishes in the sink. The children's bicycles were inside and there was an uncashed welfare check. The only thing that was missing was Norma's car, a light blue Pontiac LeMans (1965, CA plate 254SBI). It has never been found."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/33282?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/33282/Images/41630/Thumbnail"^^xsd:String .

