  rdfs:isOfAge mpr:58;
  rdfs:Case_Number mpr:MP19500;
  rdfs:DLC mpr:1993-12-17;
  rdfs:Legal_Name "Paul Armstrong"^^xsd:String;
  rdfs:Coordinates mpr:37.3021632%2C-120.4829677;
  rdfs:Missing_Age mpr:27;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.3021632%2C-120.4829677>;
  mpr:hasCircumstanceOfDisappearance """Armstrong was last seen by his girlfriend as she left for work at 7:45 a.m. His brother stopped by to check on him an hour later and found the house empty. The missing man’s wallet was still there. That day, Armstrong also failed to keep a lunch date with his girlfriend. 

He is missing along with Steven Lombard (NamUs # 19503). Both men worked at the same business as tow truck drivers, in Merced, California. Lombard's truck was found abandoned in a local business parking lot, unlocked, with the keys inside and the windows rolled down. Neither have been seen again."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/19500?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/19500/Images/29902/Thumbnail"^^xsd:String .

mpr:Merced a <http://www.dbpedia.org/ontologyMerced> .

mpr:2563 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Merced;
  rdfs:hasCountyOfOrigin mpr:Merced;
  rdfs:isOfAge mpr:65;
  rdfs:Case_Number mpr:MP19503;
  rdfs:DLC mpr:1993-12-17;
  rdfs:Legal_Name "Steven Lombard"^^xsd:String;
  rdfs:Coordinates mpr:37.3021632%2C-120.4829677;
  rdfs:Missing_Age mpr:34;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.3021632%2C-120.4829677>;
  mpr:hasCircumstanceOfDisappearance """Lombard was last seen when left home on December 17, 1993, to pick up his paycheck, then meet his wife and go Christmas shopping. He reportedly arrived at work, but was unable to pick up his paycheck due to a clerical error. Lombard's truck was recovered in the parking lot of a nearby business, unlocked, with the keys inside and the windows rolled down. 

Two hours before he was last seen, Paul Armstrong (NamUs # 19500) also vanished. Although both of the men worked for a local towing company and were acquainted, they were not close friends."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/19503?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/19503/Images/29904/Thumbnail"^^xsd:String .

