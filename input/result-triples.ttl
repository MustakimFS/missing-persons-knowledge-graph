  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/33.9806005%2C-117.3754942>;
  mpr:hasCircumstanceOfDisappearance "In July 2022, Bobby Kirby was located in Los Angeles by Los Angeles Sheriff Department and transported to an area hospital; he was discharged on 07/29/2022. Kirby's neighbor drove to the hospital and told Kirby to follow him home back to Moreno Valley. While on the 91-freeway eastbound, Kirby drove past the neighbor and continued on the freeway eastbound when the neighbor exited on 14th street. Kirby was not seen since that date and time and his phone has remained off since. Kirby's vehicle was later located on 08/06/2022 with a stolen plate attached to it and the driver of the vehicle was placed under arrest. There are no signs or communications from Kirby since that date and time."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/104095?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/104095/Images/189209/Thumbnail"^^xsd:String .

