mpr:1670 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Nipton;
  rdfs:hasCountyOfOrigin mpr:San%20Bernardino;
  rdfs:isOfAge mpr:82;
  rdfs:Case_Number mpr:MP10522;
  rdfs:DLC mpr:2008-06-07;
  rdfs:Legal_Name "Maria Estrada"^^xsd:String;
  rdfs:Coordinates mpr:35.4666532%2C-115.2722098;
  rdfs:Missing_Age mpr:66;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "Asian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/35.4666532%2C-115.2722098>;
  mpr:hasCircumstanceOfDisappearance """Maria Estrada became separated from her 64-year-old male hiking companion in a section of the Mojave National Preserve about 40 miles northwest of Needles. Estrada and her companion separated at a fork in the trail to look for their vehicle, which they both thought was located in different directions. When Estrada did not return as promised, her companion began searching on his own but waited until the following day to report her missing.
About 22 searchers from the sheriff's department and the park service covered the canyon, along with search dogs and a county helicopter, but did not locate her. 
Estrada, who is from the Philippines, had been staying with family in Blythe. 
She was last seen wearing a white long-sleeved blouse, denim shorts, white tennis shoes and a denim San Luis Obispo cap, according to a report from the National Parks Service. She was not carrying food or water."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/10522?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/10522/Images/23130/Thumbnail"^^xsd:String .

