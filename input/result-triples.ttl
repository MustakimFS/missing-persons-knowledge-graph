mpr:Waterford a <http://www.dbpedia.org/ontologyWaterford> .

mpr:3458 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:Fresh%20Pond;
  rdfs:hasCountyOfOrigin mpr:El%20Dorado;
  rdfs:isOfAge mpr:71;
  rdfs:Case_Number mpr:MP21696;
  rdfs:DLC mpr:1972-09-03;
  rdfs:Legal_Name "Paula Pope"^^xsd:String;
  rdfs:Coordinates mpr:38.7601814%2C-120.5299248;
  rdfs:Missing_Age mpr:18;
  rdfs:Bio_Sex mpr:Female;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/38.7601814%2C-120.5299248>;
  mpr:hasCircumstanceOfDisappearance "She and her husband and their friends were camping at the Cripple Creek Campground OR the Ice House Reservoir Campground near Fresh Pond, in El Dorado County. It was Labor Day weekend in 1972. She had an argument with her husband. She wanted to go to a rock concert in Carson City, Nevada. Steve couldn't go because he was on parole and he couldn't leave the state. Paula stormed out of the camper. Her friend April went after her, but came back in to get her coat. It was raining. When she went out again, she couldn't find Paula. Paula went to the concert, a couple gave her a ride from the concert to an exit off of Highway 50, near the campground. No one has seen her since. Possibly seen with biker type people after she had been dropped off at the exit."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/21696?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/21696/Images/31890/Thumbnail"^^xsd:String .

