  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.5641425%2C-122.004179>;
  mpr:hasCircumstanceOfDisappearance "Anthony Lee was last known to be in Fremont, California on June 10, 1986. On 06/12/1986, California Highway Patrol located Lee's vehicle parked in a parking lot near the Golden Gate Bridge (San Francisco, CA). Two witnesses saw an Asian male jump over side of the bridge into the water. Lee's wallet and jacket were located on the bridge nearby. His body was not recovered."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/56041?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/56041/Images/98208/Thumbnail"^^xsd:String .

