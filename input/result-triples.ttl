mpr:402 a mpr:Victim;
  rdfs:hasCityOfOrigin mpr:San%20Francisco;
  rdfs:hasCountyOfOrigin mpr:San%20Francisco;
  rdfs:isOfAge mpr:43;
  rdfs:Case_Number mpr:MP78462;
  rdfs:DLC mpr:2021-01-31;
  rdfs:Legal_Name "Michael McChesney"^^xsd:String;
  rdfs:Coordinates mpr:37.7749295%2C-122.4194155;
  rdfs:Missing_Age mpr:40;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.7749295%2C-122.4194155>;
  mpr:hasCircumstanceOfDisappearance "On 01/31/2021 at approximately 1700 hours, MP left his residence in Cupertino, CA as the family was moving out of the home. MP was upset with the move. Mother reported him missing at approximately midnight that same evening after he did not return home. Golden Gate Bridge Patrol Officers advised they made contact with MP on 2/01/2021 two times during the day and identified the subject by name. At approximately 0305 hours on 02/02/2021, CHP Officers spotted a pedestrian in a black jacket and black pants walking northbound on the east sidewalk of the bridge. They notified Bridge Patrol , exited and turned back southbound to look for the pedestrian , but were unable to locate him. GGB Patrol Sgt. located video footage at 0305 hours of the pedestrian, a white male adult, climbing over the south east gate for the east sidewalk. He was observed walking northbound on the east sidewalk out of the camera's view. A marker was deployed at the pedestrian's last known location, and Coast Guard searched the area to no avail. It is unknown if the pedestrian was in fact McChesney, or if he jumped."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/78462?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/78462/Images/160150/Thumbnail"^^xsd:String .

mpr:San%20Francisco a <http://www.dbpedia.org/ontologySan%20Francisco> .

