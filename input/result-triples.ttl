  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.0510595%2C-122.0146841>;
  mpr:hasCircumstanceOfDisappearance """On December 4th, 2017 Lorenzo Neri was reported missing by a family friend. The friend, as well as other acquaintances, reported that Neri had recently become increasingly paranoid that people were out to hurt him,
and he was possibly suffering from an undiagnosed condition. 

At approximately 4:30 AM on Dec 4th, 2017 Neri was contacted by police in the area of Scotts Valley Dr and Acorn Ct in the City of Scotts Valley (Santa Cruz County). Neri fled from officers, and has not been seen or heard from since."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/43442?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/43442/Images/81352/Thumbnail"^^xsd:String .

