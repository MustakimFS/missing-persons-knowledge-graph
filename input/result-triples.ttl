  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/37.5202145%2C-122.2758008>;
  mpr:hasCircumstanceOfDisappearance """Nancy MacDuckston was last seen at her home in Belmont on August 11, 2003, at about 8:30 a.m. On that same day, MacDuckston left her home for a day trip to the coast. 

MacDuckston's tan 2001 Mazda MPV minivan was located adjacent to State Highway 1 near Davenport in unincorporated Santa Cruz County, CA. 

MacDuckston was possibly seen at the New Davenport Store and Restaurant with an known male subject in the afternoon before her disappearance. 

Belmont Police have completed an exhaustive investigation, but turned up little information regarding MacDuckston's whereabouts."""^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/26658?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/26658/Images/36283/Thumbnail"^^xsd:String .

