  rdfs:DLC mpr:1982-04-16;
  rdfs:Legal_Name "Scott Campbell"^^xsd:String;
  rdfs:Coordinates mpr:33.8365932%2C-117.9143012;
  rdfs:Missing_Age mpr:27;
  rdfs:Bio_Sex mpr:Male;
  rdfs:Race_Ethnicity "White / Caucasian"^^xsd:String;
  rdfs:hasMapData </ser531/ontologies/MissingPersonReport#http%3A//www.google.com/maps/place/33.8365932%2C-117.9143012>;
  mpr:hasCircumstanceOfDisappearance "Campbell was last seen in Anaheim, California on April 16, 1982. Police investigating his disappearance learned that he had met with two men, planning to fly to Fargo ND. Instead the plane went west, over the Pacific ocean. One of the men was arrested after it was discovered that he had Campbell's vehicle and was in the process of stripping it, and selling the parts. The men were tried and convicted of Campbell's murder. Authorities speculate that Campbell was thrown from the plane near Catalina Island. Campbell's remains have never been recovered."^^xsd:String;
  mpr:columnURI "https://www.namus.gov/MissingPersons/Case#/51164?nav"^^xsd:String;
  mpr:hasImageURL "https://www.namus.gov/api/CaseSets/NamUs/MissingPersons/Cases/51164/Images/82922/Thumbnail"^^xsd:String .

